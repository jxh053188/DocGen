<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Manage templates and preview PDFs, but cannot save to records.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>PDF Template Editor</label>
    
    <!-- Document_Template__c (Template) permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Document_Template__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    
    <!-- Dynamic_Template_Variable__c (Template Variable) permissions -->
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>true</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Dynamic_Template_Variable__c</object>
        <viewAllRecords>true</viewAllRecords>
    </objectPermissions>
    
    <!-- Document__c permissions - read only for logs -->
    <objectPermissions>
        <allowCreate>false</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>false</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Document__c</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    
    <!-- Field permissions for Document_Template__c -->
    <!-- Note: Primary_Object__c is required, permissions cannot be set -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Document_Template__c.Html_Body__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document_Template__c.Source_Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document_Template__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document_Template__c.Renderer_Strategy__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document_Template__c.Allowed_Fields__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Document_Template__c.Version__c</field>
        <readable>true</readable>
    </fieldPermissions>
    
    <!-- Field permissions for Dynamic_Template_Variable__c -->
    <!-- Note: Template__c is MasterDetail, Path__c is required - permissions inherited/cannot be set -->
    <fieldPermissions>
        <editable>true</editable>
        <field>Dynamic_Template_Variable__c.Type__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>true</editable>
        <field>Dynamic_Template_Variable__c.Plan__c</field>
        <readable>true</readable>
    </fieldPermissions>
    
    <!-- Field permissions for Document__c - read only -->
    <!-- Note: Template__c and Target_Record_Id__c are required, permissions cannot be set -->
    <fieldPermissions>
        <editable>false</editable>
        <field>Document__c.Status__c</field>
        <readable>true</readable>
    </fieldPermissions>
    <fieldPermissions>
        <editable>false</editable>
        <field>Document__c.Error__c</field>
        <readable>true</readable>
    </fieldPermissions>
    
    <!-- Tab visibility -->
    <tabSettings>
        <tab>Document_Template__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Dynamic_Template_Variable__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    <tabSettings>
        <tab>Document__c</tab>
        <visibility>Visible</visibility>
    </tabSettings>
    
    <!-- Application visibility -->
    <applicationVisibilities>
        <application>DocGen</application>
        <visible>true</visible>
    </applicationVisibilities>
</PermissionSet>
